package exception;

import javax.swing.*;
import java.awt.*;
import java.util.ArrayList;
import gui.Main_GUI;

public class MenuBarPanel extends JPanel {

    private ArrayList<MenuButton> menuButtons = new ArrayList<>();
    private Main_GUI mainFrame;

    public MenuBarPanel(Main_GUI mainFrame) {
        this.mainFrame = mainFrame;

        setLayout(new BoxLayout(this, BoxLayout.Y_AXIS));
        setBackground(new Color(36, 170, 140));
        setPreferredSize(new Dimension(300, 0));

        // ===== TRANG CHỦ =====
        MenuButton trangChu = createMenu("Trang chủ");
        trangChu.addSubMenu("Thống kê bán hàng", "data/img/icons/chart.png", "ThongKeBanHang");
        trangChu.addSubMenu("Báo cáo doanh thu", "data/img/icons/report.png", "BaoCaoDoanhThu");
        trangChu.addSubMenu("Tra cứu giao dịch", "data/img/icons/search.png", "TraCuuGiaoDich");

        // ===== BÁN HÀNG =====
        MenuButton banHang = createMenu("Bán hàng & Giao dịch");
        banHang.addSubMenu("Lập hoá đơn", "data/img/icons/invoice.png", "LapHoaDon");
        banHang.addSubMenu("Tra cứu hoá đơn", "data/img/icons/search.png", "TraCuuHoaDon");
        banHang.addSubMenu("Đổi hàng", "data/img/icons/exchange.png", "DoiHang");
        banHang.addSubMenu("Trả hàng", "data/img/icons/return.png", "TraHang");

        // ===== SẢN PHẨM =====
        MenuButton sanPham = createMenu("Quản lý sản phẩm");
        sanPham.addSubMenu("Thêm sản phẩm", "data/img/icons/add.png", "ThemSanPham");
        sanPham.addSubMenu("Cập nhật sản phẩm", "data/img/icons/update.png", "CapNhatSanPham");
        sanPham.addSubMenu("Tra cứu sản phẩm", "data/img/icons/search.png", "TraCuuSanPham");

        // ===== KHÁCH HÀNG =====
        MenuButton khachHang = createMenu("Quản lý khách hàng");
        khachHang.addSubMenu("Thêm khách hàng", "data/img/icons/add-user.png", "ThemKhachHang");
        khachHang.addSubMenu("Cập nhật khách hàng", "data/img/icons/update.png", "CapNhatKhachHang");
        khachHang.addSubMenu("Tra cứu khách hàng", "data/img/icons/search.png", "TraCuuKhachHang");

        // ===== NHÂN VIÊN =====
        MenuButton nhanVien = createMenu("Quản lý nhân viên");
        nhanVien.addSubMenu("Thêm nhân viên", "data/img/icons/add-user.png", "ThemNhanVien");
        nhanVien.addSubMenu("Cập nhật nhân viên", "data/img/icons/update.png", "CapNhatNhanVien");
        nhanVien.addSubMenu("Tra cứu nhân viên", "data/img/icons/search.png", "TraCuuNhanVien");

        // ===== NHẬP HÀNG =====
        MenuButton nhapHang = createMenu("Quản lý nhập hàng");
        nhapHang.addSubMenu("Tạo phiếu nhập", "data/img/icons/import.png", "TaoPhieuNhap");
        nhapHang.addSubMenu("Thêm nhà cung cấp", "data/img/icons/add.png", "ThemNCC");
        nhapHang.addSubMenu("Cập nhật nhà cung cấp", "data/img/icons/update.png", "CapNhatNCC");
        nhapHang.addSubMenu("Tra cứu nhà cung cấp", "data/img/icons/search.png", "TraCuuNCC");

        // ===== CÀI ĐẶT (KHÔNG SUB) =====
        MenuButton caiDat = createSingleMenu("Cài đặt", "CaiDat");

        addMenu(trangChu);
        addMenu(banHang);
        addMenu(sanPham);
        addMenu(khachHang);
        addMenu(nhanVien);
        addMenu(nhapHang);
        addMenu(caiDat);

        add(Box.createVerticalGlue());
    }

    // ===== MENU CHA =====
    private MenuButton createMenu(String title) {
        MenuButton btn = new MenuButton(title, null);
        btn.setMenuActionListener(this::onMenuSelected);
        return btn;
    }

    // ===== MENU ĐƠN =====
    private MenuButton createSingleMenu(String title, String pageName) {
        MenuButton btn = new MenuButton(title, pageName);
        btn.setMenuActionListener(this::onMenuSelected);
        return btn;
    }

    // ===== ADD MENU =====
    private void addMenu(MenuButton btn) {
        menuButtons.add(btn);
        btn.setAlignmentX(Component.LEFT_ALIGNMENT);
        add(btn);
    }

    // ===== EVENT =====
    private void onMenuSelected(MenuButton source, String page) {

        for (MenuButton mb : menuButtons) {
            if (mb != source) {
                mb.collapse();
                mb.resetSubMenuColor();
                mb.setMainSelected(false);
            }
        }

        if (page != null) {
            mainFrame.showPage(page);
        }
    }
}